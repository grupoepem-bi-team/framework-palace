# =============================================================================
# PALACE FRAMEWORK - Environment Variables
# =============================================================================

# Ollama Cloud Configuration
OLLAMA_BASE_URL=https://ollama-cloud.local
OLLAMA_API_KEY=your-ollama-api-key-here

# Model Assignments
MODEL_ORCHESTRATOR=qwen3.5
MODEL_DEVOPS=qwen3.5
MODEL_BACKEND=qwen3-coder-next
MODEL_FRONTEND=qwen3-coder-next
MODEL_INFRA=qwen3-coder-next
MODEL_DBA=deepseek-v3.2
MODEL_QA=gemma4:31b
MODEL_DESIGNER=mistral-large
MODEL_REVIEWER=mistral-large

# Embedding Model (for vector memory)
MODEL_EMBEDDING=nomic-embed-text

# Zep Memory Store Configuration
ZEP_API_URL=http://localhost:8000
ZEP_API_KEY=your-zep-api-key-here

# Local Memory Store (Fallback - SQLite)
MEMORY_STORE_TYPE=zep
LOCAL_MEMORY_PATH=./data/memory.db

# Database Configuration (for framework state)
DATABASE_URL=sqlite+aiosqlite:///./data/palace.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# CLI Configuration
CLI_DEFAULT_PROJECT=default
CLI_HISTORY_FILE=./data/cli_history.json

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Projects Base Path
PROJECTS_BASE_PATH=./projects

# Security
API_SECRET_KEY=your-secret-key-here-change-in-production
API_ACCESS_TOKEN_EXPIRE_MINUTES=30
