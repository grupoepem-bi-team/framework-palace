# =============================================================================
# PALACE FRAMEWORK - Environment Variables
# =============================================================================
#
# Copiar este archivo como .env y completar los valores.
# Los modelos con :cloud usan Ollama Cloud (no requieren Ollama local).
#
# Modelos disponibles (Ollama Cloud):
#   - qwen3.5:cloud              → Orquestador, DevOps
#   - qwen3-coder-next:cloud     → Backend, Frontend, Infra
#   - deepseek-v3.2:cloud        → DBA
#   - gemma4:31b-cloud           → QA
#   - mistral-large-3:675b-cloud → Designer, Reviewer
#   - glm-5.1:cloud              → Alternativa general
#   - glm-5:cloud                → Alternativa general
# =============================================================================

# --- Ollama Cloud ---
# Para modelos :cloud, usar el endpoint de Ollama Cloud.
# Si tenés Ollama local instalado, usar http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_TIMEOUT=300
OLLAMA_MAX_RETRIES=3

# --- Asignación de modelos por agente ---
MODEL_ORCHESTRATOR=qwen3.5:cloud
MODEL_DEVOPS=qwen3.5:cloud
MODEL_BACKEND=qwen3-coder-next:cloud
MODEL_FRONTEND=qwen3-coder-next:cloud
MODEL_INFRA=qwen3-coder-next:cloud
MODEL_DBA=deepseek-v3.2:cloud
MODEL_QA=gemma4:31b-cloud
MODEL_DESIGNER=mistral-large-3:675b-cloud
MODEL_REVIEWER=mistral-large-3:675b-cloud

# --- Modelo de embeddings (para memoria vectorial) ---
# Si usás embeddings locales, cambiar a nomic-embed-text
MODEL_EMBEDDING=nomic-embed-text

# --- Memoria (Zep o SQLite) ---
MEMORY_STORE_TYPE=sqlite
LOCAL_MEMORY_PATH=./data/memory.db
ZEP_API_URL=http://localhost:8000
ZEP_API_KEY=

# --- Base de datos del framework ---
DATABASE_URL=sqlite+aiosqlite:///./data/palace.db
DATABASE_ECHO=false

# --- API REST ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_CORS_ORIGINS=["*"]

# --- CLI ---
CLI_DEFAULT_PROJECT=default
CLI_HISTORY_FILE=./data/cli_history.json
CLI_OUTPUT_FORMAT=text
CLI_VERBOSE=false

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Proyectos ---
PROJECTS_BASE_PATH=./projects
PROJECTS_MAX_PROJECTS=100

# --- Seguridad ---
SECRET_KEY=change-me-in-production
API_KEY_HEADER=X-API-Key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REQUIRE_AUTHENTICATION=false
